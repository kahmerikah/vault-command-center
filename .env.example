# Core
VAULT_ENV=development
SECRET_KEY=change-this-in-production
JWT_SECRET_KEY=change-this-jwt-secret
API_VERSION=v1

# Domain configuration (placeholders)
PRIMARY_DOMAIN=YOURSITE.com
OWNED_DOMAINS=YOURSITE.com
CANONICAL_FRONTEND_HOST=vault.YOURSITE.com
CANONICAL_API_HOST=api.YOURSITE.com

# Database
DATABASE_URL=postgresql+psycopg://vault:vault@postgres:5432/somb_vault

# Redis / Queue
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Frontend + CORS
FRONTEND_ORIGIN=https://vault.YOURSITE.com
ALLOWED_ORIGINS=https://vault.YOURSITE.com,https://admin.YOURSITE.com,https://api.YOURSITE.com,http://localhost:5173,http://127.0.0.1:5173,http://localhost

# Auth
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
PASSWORD_RESET_TOKEN_EXP_SECONDS=1800
SYSTEM_USERNAME=system
SYSTEM_EMAIL=system@YOURSITE.com
SYSTEM_PASSWORD=

# Email / SMS placeholders
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Plaid (bank account aggregation)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Dwolla (ACH transfers / money routing)
DWOLLA_KEY=
DWOLLA_SECRET=
DWOLLA_ENV=sandbox

# Property Intelligence
RAPIDAPI_KEY=
RAPIDAPI_HOST_ZILLOW=zillow-com1.p.rapidapi.com

# Weather (morning briefings)
OPENWEATHER_API_KEY=

# Google Calendar sync (optional)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://api.YOURSITE.com/api/v1/integrations/google/callback
GOOGLE_CALENDAR_SCOPES=openid email profile https://www.googleapis.com/auth/calendar

# Microsoft / Outlook Calendar sync (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://api.YOURSITE.com/api/v1/integrations/microsoft/callback
MICROSOFT_SCOPES=openid email profile offline_access User.Read Calendars.ReadWrite

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=/app/storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Feature flags
ENABLE_BOOKING=true
ENABLE_BLOCKCHAIN=true
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_FINANCIAL_OS=true
ENABLE_PROPERTY_INTEL=true
ENABLE_KNOWLEDGE_OS=true

# Platform chain bootstrap
PLATFORM_GENESIS_SUPPLY=1000000

# API keys (comma-separated bootstrap list)
BOOTSTRAP_API_KEYS=
